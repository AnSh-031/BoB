generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Auditor {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String
  bank      String
  createdAt DateTime @default(now())
}