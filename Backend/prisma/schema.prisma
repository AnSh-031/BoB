generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  BANK_ADMIN
  BANK_AUDITOR
  BANK_OPERATOR
}

model Auditor {
  id                Int      @id @default(autoincrement())
  email             String   @unique
  password          String
  role              Role     @default(BANK_OPERATOR)
  bank              String
  mustChangePassword Boolean  @default(true)
  createdAt         DateTime @default(now())
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  email     String
  role      String
  action    String
  ipAddress String?
  status    String
  createdAt DateTime @default(now())
}